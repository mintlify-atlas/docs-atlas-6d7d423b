  "keyFeatures": [
    "YAML-based flow definitions for building processing pipelines",
    "Docker-based node execution with presigned URL handling",
    "Resource tier management (CPU, memory, GPU) with independent worker scaling",
    "Controller/worker architecture with Redis-backed task queue",
    "Multiple storage backend support (S3, local filesystem)",
    "Flow validation and testing tools",
    "REST API for remote execution and monitoring",
    "Local development mode with integrated controller and worker"
  ],
  "publicApiSurface": [
    "pup init - Initialize new project",
    "pup dev - Start development server",
    "pup test - Test flow execution",
    "pup validate - Validate flow definitions",
    "pup push - Push project to controller",
    "pup controller add/list/remove - Manage controllers",
    "POST /v1/flow/test - Execute flow test",
    "GET /v1/flow/status/{flowRunID} - Get flow run status",
    "GET /v1/project/{projectID} - Get project details",
    "POST /v1/project/{projectID} - Save project",
    "POST /v1/project/{projectID}/flows/{flowName} - Execute flow"
  ]
}
